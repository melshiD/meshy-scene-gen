# Required API keys
MESHY_API_KEY=your_meshy_api_key_here
# On lodestar-core-1 this is the app's LiteLLM VIRTUAL key (with OPENAI_BASE_URL below);
# for standalone dev it can be a real OpenAI key (leave OPENAI_BASE_URL unset).
OPENAI_API_KEY=your_openai_api_key_here
#OPENAI_BASE_URL=http://litellm:4000/v1

# Postgres (jobs, presets, AND binary assets via the Asset table).
# Unset => dev fallback: filesystem storage under public/generated, but job/preset routes need a DB.
#DATABASE_URL=postgresql://user:password@host:5432/meshy_scene_gen

# Cloudflare R2 (optional object storage — NOT used on lodestar core; all four vars must be set
# to activate it, plus STORAGE_PUBLIC_URL as the bucket's public base URL)
#R2_ACCOUNT_ID=
#R2_ACCESS_KEY_ID=
#R2_SECRET_ACCESS_KEY=
#R2_BUCKET_NAME=
#STORAGE_PUBLIC_URL=
